# Oracle to consume (Phase 2 service)
ORACLE_URL=http://localhost:3001
ORACLE_WALLET_ADDRESS=0xe2F7a0E6d9865C7Dc9B5D19DCc11CBcb4655c661   # oracle's registered wallet

# Consumer agent identity
CONSUMER_PRIVATE_KEY=0x...
CONSUMER_WALLET_ADDRESS=0x...

# Bond contract (from arcid2 deploy)
BOND_CONTRACT_ADDRESS=0x...
ARC_RPC_URL=http://127.0.0.1:8545   # local Hardhat node; set to Arc testnet RPC for prod

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6

# Loop
POLL_INTERVAL_MS=12000   # 12 seconds

# DEV_MODE: skip real on-chain slash + accept dev x402 payments + simulate settlement
DEV_MODE=true
