# Oracle agent identity
# This wallet must be TEE-registered in ArcIDRegistry on Arc testnet.
# The private key signs every response — a wrong answer is attributable to this wallet.
ORACLE_PRIVATE_KEY=0x...
ORACLE_WALLET_ADDRESS=0x...

# x402 payment config
PRICE_USDC=0.001
ARC_NETWORK=arc-testnet
FACILITATOR_URL=https://x402.org/facilitator

# Service SLA — consumer agent enforces this
MAX_AGE_SECONDS=30

# DEV_MODE=true → skip real payment verification (any X-Payment header accepted).
# Set to false on Arc testnet.
DEV_MODE=true

# Port
PORT=3000

# Fault-mode protection in production (any secret string)
# Required on /admin/fault, /admin/fault/reset, and /admin/trigger-cycle whenever DEV_MODE=false.
FAULT_TOKEN=change-me-in-production

# On-chain trigger-cycle + chain-stats config
ARC_RPC_URL=https://rpc.testnet.arc.network
BOND_CONTRACT_ADDRESS=
REGISTRY_ADDRESS=
DEPLOY_BLOCK=0
CONSUMER_PRIVATE_KEY=0x...
CONSUMER_WALLET_ADDRESS=0x...
ANTHROPIC_API_KEY=sk-ant-...
# Adjudication model for /admin/trigger-cycle and the consumer agent.
# Keep this on Sonnet/Haiku, not Opus — trigger-cycle runs a full re-bond -> adjudicate -> slash
# loop per call, so an exposed/misused endpoint on Opus gets expensive fast (see incident notes).
MODEL=claude-sonnet-4-6

# Phase 5 — USYC yield-bearing bond (set after deploy_usyc.js)
USYC_BOND_ADDRESS=
USDC_BOND_ADDRESS=
USYC_TOKEN_ADDRESS=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C
TELLER_ADDRESS=0x9fdF14c5B14173D74C08Af27AebFf39240dC105A

# Phala Cloud TDX attestation (Phase 7 — Phala CVM deployment)
# USE_REAL_PHALA=true  → GET /api/attest calls Phala dstack at PHALA_ENDPOINT/attestation/quote
#                         Only works inside a Phala TDX CVM; set this when deploying to Phala Cloud.
# USE_REAL_PHALA=false → /api/attest returns a structurally-valid prototype quote (local dev default).
USE_REAL_PHALA=false
PHALA_ENDPOINT=http://127.0.0.1:9000
