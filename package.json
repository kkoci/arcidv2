{
  "name": "arcid-bond",
  "version": "2.0.0",
  "description": "ArcIDBond — bonded agent reputation for nanopayment networks on Arc",
  "scripts": {
    "compile":            "hardhat compile",
    "test":               "hardhat test",
    "deploy:local":       "hardhat run scripts/deploy.js --network hardhat",
    "deploy:arc":         "hardhat run scripts/deploy.js --network arcTestnet",
    "deploy:usyc:local":  "hardhat run scripts/deploy_usyc.js --network hardhat",
    "deploy:usyc:arc":    "hardhat run scripts/deploy_usyc.js --network arcTestnet",
    "mint:usyc:arc":      "hardhat run scripts/mint_usyc.js --network arcTestnet",
    "gating:local":       "hardhat run scripts/verify_gating.js --network hardhat",
    "gating:arc":         "hardhat run scripts/verify_gating.js --network arcTestnet",
    "deploy:standalone":       "hardhat run scripts/deploy_standalone.js --network arcTestnet",
    "deploy:standalone:local": "hardhat run scripts/deploy_standalone.js --network hardhat",
    "deploy:standalone:node":  "hardhat run scripts/deploy_standalone.js --network localhost",
    "agent:register":     "node scripts/cli/register.js",
    "agent:status":       "node scripts/cli/status.js",
    "agent:list":         "node scripts/cli/list-agents.js",
    "bond:post":          "node scripts/cli/post-bond.js",
    "bond:slash":         "node scripts/cli/slash.js",
    "bond:settle":        "node scripts/cli/settle.js",
    "gating:check":       "node scripts/cli/gating-check.js",
    "node":               "hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.4"
  }
}
