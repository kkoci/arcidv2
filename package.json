{
  "name": "arcid-bond",
  "version": "2.0.0",
  "description": "ArcIDBond — bonded agent reputation for nanopayment networks on Arc",
  "scripts": {
    "compile":       "hardhat compile",
    "test":          "hardhat test",
    "deploy:local":  "hardhat run scripts/deploy.js --network hardhat",
