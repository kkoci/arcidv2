    "gating:arc":    "hardhat run scripts/verify_gating.js --network arcTestnet",
    "node":          "hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.4"
  }
}
